# Local-dev env for `task run` (copied to .env, loaded via Taskfile dotenv).
# In-cluster these come from the connection Secret via envFrom — see
# examples/connection-secret.yaml.
CONFIG_FILE=examples/config.yaml

S3_ALIAS=homerun
S3_ENDPOINT=https://minio.sthings.lab
S3_REGION=us-east-1
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME

# TLS trust — set ONE (or neither for a public CA):
# S3_CA_BUNDLE_FILE=/path/to/ca.pem
S3_INSECURE_SKIP_VERIFY=false
